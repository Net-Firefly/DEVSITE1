# Kai chatbot now uses the backend endpoint for AI.
# Do not put OpenAI secrets in frontend env.
# Configure OPENAI_API_KEY in server/.env instead.

# API base URLs (use your PC LAN IP when testing on phone)
VITE_API_BASE_URL=http://localhost/tripple-kay-api
VITE_SERVER_BASE_URL=http://localhost:5000

# If using an API path under XAMPP (for PHP backend), set:
# VITE_API_BASE_URL=http://localhost/tripple-kay-api
# VITE_SERVER_BASE_URL=http://localhost:5000
